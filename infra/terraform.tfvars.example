# Copy this to terraform.tfvars and fill in your values.
# Never commit terraform.tfvars — it contains your secret_key.

key_pair_name    = "your-keypair-name"          # Must already exist in EC2 console
ssh_allowed_cidr = "1.2.3.4/32"                 # Your IP: curl ifconfig.me/ip
secret_key       = "replace-with-openssl-rand-hex-32"
aws_region       = "us-east-1"
